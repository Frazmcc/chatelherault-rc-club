# Frontend proxy endpoint used by the meetups weather panel.
VITE_METOFFICE_PROXY_URL=/api/metoffice-forecast

# Optional local-development fallback only (browser direct call).
# Leave unset in production to keep keys server-side.
VITE_METOFFICE_API_KEY=

# Optional override for direct fallback endpoint.
VITE_METOFFICE_HOURLY_URL=https://data.hub.api.metoffice.gov.uk/sitespecific/v0/point/hourly

# Server-side (Cloudflare Pages Functions) variables:
# METOFFICE_API_KEY=your_met_office_datahub_api_key
# METOFFICE_MONTHLY_BUDGET_BYTES=943718400
# METOFFICE_BUDGET_SAFETY_BYTES=10485760
# METOFFICE_DAILY_CALL_LIMIT=350
# METOFFICE_CACHE_TTL_SECONDS=10800
# KV binding required for strict enforcement: METOFFICE_BUDGET_KV
